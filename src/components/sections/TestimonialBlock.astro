---
import { flags } from '../../data/site';
import { testimonials } from '../../data/testimonials';
import { site } from '../../data/site';

interface Props {
  heading?: string;
  serviceTag?: string;
  cityTag?: string;
}

const { heading = 'What Our Customers Say', serviceTag, cityTag } = Astro.props;

const showExcerpts = flags.show_review_excerpts;
const filteredTestimonials = testimonials.filter((t) => {
  if (serviceTag && t.serviceTag !== serviceTag) return false;
  if (cityTag && t.cityTag && t.cityTag !== cityTag) return false;
  return true;
});
---
<div>
  <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-indigo mb-8">{heading}</h2>

  {showExcerpts && filteredTestimonials.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {filteredTestimonials.slice(0, 3).map((testimonial) => (
        <div class="bg-white rounded-xl shadow-md p-6">
          <div class="flex gap-1 mb-3">
            {[1, 2, 3, 4, 5].map(() => (
              <svg class="w-5 h-5 text-brand-cta" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-text-muted text-sm leading-relaxed mb-4">"{testimonial.text}"</p>
          <p class="text-sm font-semibold text-brand-indigo">— {testimonial.author}</p>
        </div>
      ))}
    </div>
  ) : (
    <div class="bg-white rounded-xl shadow-md p-8 text-center max-w-xl mx-auto">
      <p class="text-text-muted mb-4">
        We are proud of our reputation. See what our customers say on Google.
      </p>
      <a
        href={site.gbp.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-moonstone hover:text-brand-indigo font-semibold transition-colors"
      >
        Read our reviews on Google
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  )}
</div>
