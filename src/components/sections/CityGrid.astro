---
import type { City } from '../../types';
import Card from '../ui/Card.astro';
import CardGrid from '../ui/CardGrid.astro';

interface Props {
  cities: City[];
  heading?: string;
}

const { cities, heading = 'Areas We Serve' } = Astro.props;
---
<div>
  <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-indigo mb-8">{heading}</h2>
  <CardGrid columns={4}>
    {cities.map((city) => (
      <Card href={`/${city.slug}/`}>
        <div class="text-center">
          <div class="w-12 h-12 bg-surface-subtle rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-brand-moonstone" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-indigo">{city.name}, CA</h3>
          <p class="text-sm text-text-muted mt-1">Electrical services</p>
        </div>
      </Card>
    ))}
  </CardGrid>
</div>
