---
import { site } from '../../data/site';

const trustItems = [
  `Established ${site.established}`,
  site.license,
  'Licensed, Bonded & Insured',
  '1-Year Labor Warranty',
];
---
<div class="bg-surface-subtle border-y border-brand-mint/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-2">
      {trustItems.map((item, index) => (
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-brand-moonstone shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-sm font-medium text-text-muted whitespace-nowrap">{item}</span>
        </div>
      ))}
    </div>
  </div>
</div>
