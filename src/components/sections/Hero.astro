---
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  showCTAs?: boolean;
}

const { eyebrow, title, subtitle, showCTAs = true } = Astro.props;
---
<section class="bg-brand-indigo relative overflow-hidden">
  <!-- Decorative background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-moonstone rounded-full -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-brand-picton rounded-full translate-y-1/3 -translate-x-1/4"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-32 text-center">
    {eyebrow && (
      <span class="inline-block bg-brand-moonstone/20 text-brand-columbia text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
        {eyebrow}
      </span>
    )}
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white mb-6 max-w-4xl mx-auto leading-tight">
      {title}
    </h1>
    {subtitle && (
      <p class="text-lg md:text-xl text-brand-columbia mb-10 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}
    {showCTAs && (
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="/free-estimates/" variant="primary" size="lg">
          Free Estimate
        </Button>
        <Button href={`tel:${site.nap.phoneTel}`} variant="outline-white" size="lg">
          Call {site.nap.phone}
        </Button>
      </div>
    )}
  </div>
</section>
