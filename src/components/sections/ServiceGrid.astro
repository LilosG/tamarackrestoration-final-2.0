---
import type { ServicePillar } from '../../types';
import Card from '../ui/Card.astro';
import CardGrid from '../ui/CardGrid.astro';

interface Props {
  services: ServicePillar[];
  citySlug?: string;
  heading?: string;
}

const { services, citySlug, heading = 'Our Electrical Services' } = Astro.props;
---
<div>
  <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-indigo mb-8">{heading}</h2>
  <CardGrid columns={3}>
    {services.map((service) => {
      const href = citySlug
        ? `/${citySlug}/${service.slug}/`
        : `/services/${service.slug}/`;
      return (
        <Card href={href}>
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-12 h-12 bg-surface-subtle rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-moonstone" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-brand-indigo mb-2">{service.name}</h3>
              <p class="text-sm text-text-muted leading-relaxed">{service.shortDesc}</p>
            </div>
          </div>
        </Card>
      );
    })}
  </CardGrid>
</div>
