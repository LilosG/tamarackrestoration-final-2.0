---
import Icon from '@/components/ui/Icon.astro';

export interface PriorityInternalLink {
  label: string;
  href: string;
  description?: string;
}

export interface PriorityInternalLinkGroup {
  title: string;
  description?: string;
  links: PriorityInternalLink[];
}

interface Props {
  title: string;
  subtitle?: string;
  groups: PriorityInternalLinkGroup[];
  class?: string;
}

const { title, subtitle, groups, class: className = 'bg-white' } = Astro.props;
const visibleGroups = groups
  .map((group) => ({ ...group, links: group.links.slice(0, 6) }))
  .filter((group) => group.links.length > 0);
---

{visibleGroups.length > 0 && (
  <section class:list={['section', className]}>
    <div class="container">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <h2 class="mb-4 font-heading text-3xl font-bold text-brand-black md:text-4xl">
          {title}
        </h2>
        {subtitle && <p class="text-lg text-brand-gray">{subtitle}</p>}
      </div>

      <div class:list={['mx-auto grid gap-6', visibleGroups.length === 1 ? 'max-w-3xl' : 'max-w-6xl lg:grid-cols-2']}>
        {visibleGroups.map((group) => (
          <div class="rounded-2xl bg-white p-6 shadow-soft ring-1 ring-brand-cream-300">
            <div class="mb-5">
              <h3 class="font-heading text-xl font-bold text-brand-black">{group.title}</h3>
              {group.description && <p class="mt-2 text-sm leading-relaxed text-brand-gray">{group.description}</p>}
            </div>

            <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
              {group.links.map((link) => (
                <a
                  href={link.href}
                  class="group flex h-full items-start gap-3 rounded-xl border border-brand-cream-300 bg-brand-cream-100 p-4 transition-colors hover:border-brand-orange hover:bg-brand-orange-50"
                >
                  <span class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-lg bg-brand-orange-100 text-brand-orange group-hover:bg-brand-orange group-hover:text-white">
                    <Icon name="arrow-right" size="sm" />
                  </span>
                  <span>
                    <span class="block font-heading font-semibold leading-snug text-brand-black group-hover:text-brand-orange">
                      {link.label}
                    </span>
                    {link.description && <span class="mt-1 block text-sm leading-relaxed text-brand-gray">{link.description}</span>}
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
