---
import { buildNavigation, ctaNav } from '../../data/navigation';
import { site } from '../../data/site';
import Button from '../ui/Button.astro';

const nav = buildNavigation();
---
<header class="bg-white shadow-sm sticky top-0 z-50">
  <!-- Top bar with phone -->
  <div class="bg-brand-indigo text-white text-sm py-2 hidden md:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
      <span>{site.hours.formatted}</span>
      <div class="flex items-center gap-4">
        <a href={`mailto:${site.nap.email}`} class="hover:text-brand-columbia transition-colors">{site.nap.email}</a>
        <a href={`tel:${site.nap.phoneTel}`} class="font-semibold hover:text-brand-columbia transition-colors">{site.nap.phone}</a>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-xl lg:text-2xl font-heading font-bold text-brand-indigo">Wheyland Electric</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {nav.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-text hover:text-brand-moonstone transition-colors"
            >
              {item.label}
              {item.children && (
                <svg class="inline-block w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <div class="bg-white rounded-lg shadow-lg border border-brand-mint py-2 min-w-[220px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-text hover:bg-surface-subtle hover:text-brand-moonstone transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      <!-- CTA buttons (desktop) -->
      <div class="hidden lg:flex items-center gap-3">
        <a href={`tel:${site.nap.phoneTel}`} class="text-sm font-semibold text-brand-indigo hover:text-brand-moonstone transition-colors">
          {site.nap.phone}
        </a>
        <Button href={ctaNav.estimate.href} variant="primary" size="sm">
          {ctaNav.estimate.label}
        </Button>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden p-2 text-brand-indigo hover:text-brand-moonstone transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav overlay -->
  <div id="mobile-menu" class="hidden fixed inset-0 z-50 lg:hidden">
    <div class="fixed inset-0 bg-black/50" id="mobile-menu-backdrop"></div>
    <div class="fixed right-0 top-0 bottom-0 w-80 max-w-[85vw] bg-white shadow-xl overflow-y-auto">
      <div class="p-4">
        <div class="flex items-center justify-between mb-6">
          <span class="font-heading font-bold text-brand-indigo text-lg">Menu</span>
          <button id="mobile-menu-close" class="p-2 text-text-muted hover:text-brand-indigo" aria-label="Close menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <nav class="space-y-1" aria-label="Mobile navigation">
          {nav.map((item) => (
            <div>
              <a href={item.href} class="block px-3 py-3 text-base font-medium text-text hover:bg-surface-subtle rounded-lg transition-colors">
                {item.label}
              </a>
              {item.children && (
                <div class="ml-4 space-y-1">
                  {item.children.map((child) => (
                    <a href={child.href} class="block px-3 py-2 text-sm text-text-muted hover:text-brand-moonstone transition-colors">
                      {child.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </nav>
        <div class="mt-6 space-y-3 px-3">
          <a href={`tel:${site.nap.phoneTel}`} class="block text-center font-semibold text-brand-indigo py-3 border-2 border-brand-indigo rounded-lg hover:bg-brand-indigo hover:text-white transition-colors">
            Call {site.nap.phone}
          </a>
          <a href={ctaNav.estimate.href} class="block text-center font-semibold text-white bg-brand-cta hover:bg-brand-cta-hover py-3 rounded-lg transition-colors">
            Free Estimate
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('mobile-menu-close');
  const backdrop = document.getElementById('mobile-menu-backdrop');

  function openMenu() {
    menu?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
</script>
