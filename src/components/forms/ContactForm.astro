---
/**
 * ContactForm Component
 * =====================
 * Full contact form with image upload
 * Posts to Cloudflare Worker → R2 (images) + Resend (email)
 */

import Button from '@/components/ui/Button.astro';
import PhoneCTA from '@/components/PhoneCTA.astro';
import { formConfig, business } from '@/data/site';

interface Props {
  class?: string;
  source?: string;
}

const {
  class: className,
  source = 'contact-page'
} = Astro.props;

const formId = `contact-form-${Math.random().toString(36).slice(2, 11)}`;

const selectArrow = "background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%2360605f%27 stroke-width=%272%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27%3e%3cpolyline points=%276 9 12 15 18 9%27%3e%3c/polyline%3e%3c/svg%3e'); background-position: right 0.75rem center; background-size: 1.25rem;";

const inputClass = "w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-brand-black placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-orange focus:border-transparent transition-all text-sm";
const selectClass = `${inputClass} appearance-none bg-no-repeat pr-10 cursor-pointer`;
const labelClass = "block text-sm font-semibold text-brand-black mb-1.5";
---

<div class:list={[className]}>
  <p class="text-sm text-brand-gray mb-8">
    Fields marked with <span class="text-brand-orange font-semibold">*</span> are required.
  </p>

  <form
    id={formId}
    class="space-y-5"
    data-contact-form
    data-worker-url={formConfig.workerEndpoint}
    novalidate
  >
    <!-- Honeypot -->
    <input type="text" name="_gotcha" style="display:none !important" tabindex="-1" autocomplete="off" />

    <!-- Hidden tracking fields -->
    <input type="hidden" name="source"       value={source} />
    <input type="hidden" name="utm_source"   value="" data-utm-source />
    <input type="hidden" name="utm_medium"   value="" data-utm-medium />
    <input type="hidden" name="utm_campaign" value="" data-utm-campaign />
    <input type="hidden" name="page_url"     value="" data-page-url />

    <!-- Name & Phone -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label for={`${formId}-name`} class={labelClass}>
          Your Name <span class="text-brand-orange">*</span>
        </label>
        <input
          type="text"
          id={`${formId}-name`}
          name="name"
          required
          autocomplete="name"
          placeholder="Your full name"
          class={inputClass}
        />
      </div>
      <div>
        <label for={`${formId}-phone`} class={labelClass}>
          Phone Number <span class="text-brand-orange">*</span>
        </label>
        <input
          type="tel"
          id={`${formId}-phone`}
          name="phone"
          required
          autocomplete="tel"
          placeholder="(760) 555-1234"
          class={inputClass}
        />
      </div>
    </div>

    <!-- Email & Address -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label for={`${formId}-email`} class={labelClass}>
          Email Address <span class="text-brand-orange">*</span>
        </label>
        <input
          type="email"
          id={`${formId}-email`}
          name="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          class={inputClass}
        />
      </div>
      <div>
        <label for={`${formId}-address`} class={labelClass}>
          Property Address
          <span class="text-gray-400 font-normal ml-1">(optional)</span>
        </label>
        <input
          type="text"
          id={`${formId}-address`}
          name="address"
          autocomplete="street-address"
          placeholder="123 Main St, Carlsbad CA"
          class={inputClass}
        />
      </div>
    </div>

    <!-- Service & Urgency -->
    <div class="grid sm:grid-cols-2 gap-4">
      <div>
        <label for={`${formId}-service`} class={labelClass}>
          Service Needed <span class="text-brand-orange">*</span>
        </label>
        <select
          id={`${formId}-service`}
          name="serviceType"
          required
          data-service-select
          class={selectClass}
          style={selectArrow}
        >
          <option value="">Select a Service</option>
          {formConfig.services.map((s) => (
            <option value={s.value}>{s.label}</option>
          ))}
        </select>
      </div>
      <div>
        <label for={`${formId}-urgency`} class={labelClass}>
          Urgency Level <span class="text-brand-orange">*</span>
        </label>
        <select
          id={`${formId}-urgency`}
          name="urgency"
          required
          class={selectClass}
          style={selectArrow}
        >
          <option value="">How Urgent Is This?</option>
          {formConfig.urgencyLevels.map((u) => (
            <option value={u.value}>{u.label}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Conditional: Water / Fire / Storm / Flood / Sewage -->
    <div data-service-fields="water-damage-restoration water-leak-repair fire-damage-restoration flood-cleanup sewage-cleanup storm" style="display:none">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class={labelClass}>Affected Areas</label>
          <input
            type="text"
            name="affectedAreas"
            placeholder="e.g. Kitchen, Living Room, Master Bedroom"
            class={inputClass}
          />
        </div>
        <div>
          <label class={labelClass}>Source of Damage</label>
          <input
            type="text"
            name="damageSource"
            placeholder="e.g. Burst pipe, roof leak"
            class={inputClass}
          />
        </div>
      </div>
    </div>

    <!-- Conditional: Mold -->
    <div data-service-fields="mold-removal" style="display:none">
      <div class="grid sm:grid-cols-2 gap-4">
        <div>
          <label class={labelClass}>Affected Areas</label>
          <input
            type="text"
            name="affectedAreas"
            placeholder="e.g. Bathroom, Crawl Space"
            class={inputClass}
          />
        </div>
        <div>
          <label class={labelClass}>Approx. Square Footage</label>
          <input
            type="text"
            name="squareFootage"
            placeholder="e.g. 200 sq ft"
            class={inputClass}
          />
        </div>
        <div class="sm:col-span-2">
          <label class={labelClass}>Is Mold Visible?</label>
          <select name="moldVisible" class={selectClass} style={selectArrow}>
            <option value="">Select...</option>
            <option value="yes">Yes — visible growth</option>
            <option value="suspected">Suspected but not visible</option>
            <option value="no">No</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Situation Description -->
    <div>
      <label for={`${formId}-description`} class={labelClass}>
        Tell Us About Your Situation <span class="text-brand-orange">*</span>
      </label>
      <textarea
        id={`${formId}-description`}
        name="description"
        required
        rows="4"
        placeholder="Describe what happened, when it started, and any other details that would help us respond quickly."
        class={`${inputClass} resize-y min-h-[110px]`}
      ></textarea>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-100 pt-5">
      <p class={labelClass}>
        Attach Photos
        <span class="text-gray-400 font-normal ml-1">(optional)</span>
      </p>
      <p class="text-xs text-brand-gray mb-3 leading-relaxed">
        Photos of the damage help us give a faster, more accurate estimate — water intrusion points, affected rooms, visible mold, or any relevant areas. JPG, PNG, HEIC accepted. Max 10MB per photo.
      </p>

      <label
        for={`${formId}-images`}
        data-upload-zone
        class="flex flex-col items-center justify-center w-full px-6 py-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 cursor-pointer hover:border-brand-orange hover:bg-orange-50 transition-all duration-200 group"
      >
        <div class="w-12 h-12 rounded-full bg-white border border-gray-200 flex items-center justify-center mb-3 group-hover:border-brand-orange group-hover:bg-orange-50 transition-all">
          <svg class="w-5 h-5 text-gray-400 group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
          </svg>
        </div>
        <span data-upload-label-text class="text-sm font-semibold text-gray-600 group-hover:text-brand-black transition-colors">
          Click to upload photos
        </span>
        <span class="text-xs text-gray-400 mt-1">or drag and drop</span>
        <input
          type="file"
          id={`${formId}-images`}
          name="images"
          accept="image/*"
          multiple
          data-image-input
          style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0"
        />
      </label>

      <!-- Thumbnail previews -->
      <div data-preview-grid class="mt-3 grid grid-cols-4 sm:grid-cols-6 gap-2" style="display:none"></div>
    </div>

    <!-- Submit -->
    <div class="pt-2">
      <Button
        type="submit"
        variant="primary"
        size="lg"
        fullWidth
        data-submit-btn
      >
        Send Message
      </Button>
      <p class="text-xs text-gray-400 text-center mt-3">
        For emergencies, call us directly at{" "}
        <PhoneCTA
          phone={business.phone}
          phoneFormatted={business.phoneFormatted}
          ctaLocation="contact_form"
          class="text-brand-orange font-semibold hover:underline"
        />
      </p>
    </div>

    <!-- Status messages -->
    <div data-form-status style="display:none" aria-live="polite">
      <div data-status-success class="p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm text-center font-medium" style="display:none">
        ✓ Request received! We'll be in touch shortly.
      </div>
      <div data-status-error class="p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm text-center font-medium" style="display:none">
        Something went wrong. Please call us directly at (760) 500-2211.
      </div>
    </div>

  </form>
</div>

<script>
  function initContactForm() {
    const forms = document.querySelectorAll('[data-contact-form]');

    forms.forEach((formEl) => {
      const form          = formEl as HTMLFormElement;
      const workerUrl     = (form as HTMLElement).dataset.workerUrl!;
      const submitBtn     = form.querySelector('[data-submit-btn]') as HTMLButtonElement;
      const statusDiv     = form.querySelector('[data-form-status]') as HTMLElement;
      const successMsg    = form.querySelector('[data-status-success]') as HTMLElement;
      const errorMsg      = form.querySelector('[data-status-error]') as HTMLElement;
      const serviceSelect = form.querySelector('[data-service-select]') as HTMLSelectElement;
      const imageInput    = form.querySelector('[data-image-input]') as HTMLInputElement;
      const previewGrid   = form.querySelector('[data-preview-grid]') as HTMLElement;
      const uploadZone    = form.querySelector('[data-upload-zone]') as HTMLElement;
      const uploadLabelText = form.querySelector('[data-upload-label-text]') as HTMLElement;

      // UTM capture
      const params = new URLSearchParams(window.location.search);
      (form.querySelector('[data-utm-source]') as HTMLInputElement).value   = params.get('utm_source')   || 'direct';
      (form.querySelector('[data-utm-medium]') as HTMLInputElement).value   = params.get('utm_medium')   || '';
      (form.querySelector('[data-utm-campaign]') as HTMLInputElement).value = params.get('utm_campaign') || '';
      (form.querySelector('[data-page-url]') as HTMLInputElement).value     = window.location.href;

      // Conditional fields — using inline style display to avoid Tailwind hidden/grid conflict
      function updateConditionalFields() {
        const val = serviceSelect?.value || '';
        const allGroups = form.querySelectorAll('[data-service-fields]');
        allGroups.forEach((group) => {
          const el       = group as HTMLElement;
          const services = el.dataset.serviceFields!.split(' ');
          const show     = services.includes(val);
          el.style.display = show ? 'block' : 'none';
          if (!show) {
            el.querySelectorAll('input, select, textarea').forEach((input) => {
              (input as HTMLInputElement).value = '';
            });
          }
        });
      }

      serviceSelect?.addEventListener('change', updateConditionalFields);
      updateConditionalFields();

      // Image preview
      imageInput?.addEventListener('change', () => {
        const files = Array.from(imageInput.files || []);
        if (!files.length) return;

        previewGrid.innerHTML = '';
        previewGrid.style.display = 'grid';

        files.forEach((file) => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const wrapper = document.createElement('div');
            wrapper.className = 'relative aspect-square rounded-lg overflow-hidden bg-gray-100 border border-gray-200';
            const img = document.createElement('img');
            img.src       = e.target!.result as string;
            img.className = 'w-full h-full object-cover';
            img.alt       = file.name;
            wrapper.appendChild(img);
            previewGrid.appendChild(wrapper);
          };
          reader.readAsDataURL(file);
        });

        if (uploadLabelText) {
          uploadLabelText.textContent = `${files.length} photo${files.length !== 1 ? 's' : ''} selected — click to change`;
        }
      });

      // Drag and drop
      uploadZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadZone.classList.add('border-brand-orange', 'bg-orange-50');
      });
      uploadZone?.addEventListener('dragleave', () => {
        uploadZone.classList.remove('border-brand-orange', 'bg-orange-50');
      });
      uploadZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadZone.classList.remove('border-brand-orange', 'bg-orange-50');
        if (e.dataTransfer?.files && imageInput) {
          const dt = new DataTransfer();
          Array.from(e.dataTransfer.files).forEach(f => dt.items.add(f));
          imageInput.files = dt.files;
          imageInput.dispatchEvent(new Event('change'));
        }
      });

      // Submit
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const honeypot = (form.querySelector('[name="_gotcha"]') as HTMLInputElement)?.value;
        if (honeypot) return;

        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          <svg class="animate-spin h-4 w-4 mr-2 inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          Sending...
        `;

        try {
          const formData = new FormData(form);
          const res      = await fetch(workerUrl, { method: 'POST', body: formData });
          const data     = await res.json();

          if (res.ok && data.success) {
            statusDiv.style.display = 'block';
            successMsg.style.display = 'block';
            errorMsg.style.display   = 'none';
            form.reset();
            previewGrid.style.display = 'none';
            previewGrid.innerHTML     = '';
            if (uploadLabelText) uploadLabelText.textContent = 'Click to upload photos';
            updateConditionalFields();

            if (typeof window !== 'undefined' && (window as any).gtag) {
              (window as any).gtag('event', 'webform_submit', {
                form_name: 'contact_form',
                page_path: window.location.pathname,
              });
            }
          } else {
            throw new Error(data.error || 'Submission failed');
          }
        } catch {
          statusDiv.style.display  = 'block';
          successMsg.style.display = 'none';
          errorMsg.style.display   = 'block';
        } finally {
          submitBtn.disabled       = false;
          submitBtn.innerHTML      = 'Send Message';
        }
      });
    });
  }

  initContactForm();
  document.addEventListener('astro:page-load', initContactForm);
</script>
