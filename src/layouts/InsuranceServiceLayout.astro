---
/**
 * Insurance Service Layout
 * ========================
 * Template for /insurance/[carrier]/[service]/ pages
 * Enhanced with rich content from insuranceCarrierContent and insuranceServiceContent
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Icon from '@/components/ui/Icon.astro';
import PhoneCTA from '@/components/PhoneCTA.astro';
import TrustBar from '@/components/sections/TrustBar.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import FAQ from '@/components/sections/FAQ.astro';
import LeadForm from '@/components/forms/LeadForm.astro';
import { insuranceCarriers, services, business, cities } from '@/data/site';
import { insuranceServiceContent, serviceContent } from '@/data/content';
import { getCanonicalUrl, getBreadcrumbSchema, getServiceSchema, getFAQSchema, combineSchemas } from '@/utils/seo';
import type { FAQ as FAQType } from '@/types';

interface Props {
  carrierSlug: string;
  serviceSlug: string;
}

const { carrierSlug, serviceSlug } = Astro.props;

const carrier = insuranceCarriers.find(c => c.slug === carrierSlug)!;
const service = services.find(s => s.slug === serviceSlug)!;
const insuranceService = insuranceServiceContent[serviceSlug] || null;
const svcContent = serviceContent[serviceSlug] || null;

// SEO
const title = `${carrier.name} ${service.name} Claims | Tamarack Restoration`;
const description = `${service.name} after a loss with ${carrier.name}? We provide mitigation, documentation, and adjuster communication support in North San Diego County. Coverage depends on your policy, cause of loss, and carrier review. Call ${business.phoneFormatted}.`;
const canonical = getCanonicalUrl(`/insurance/${carrier.slug}/${service.slug}/`);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Insurance', href: '/insurance/' },
  { label: carrier.name, href: `/insurance/${carrier.slug}/` },
  { label: service.name, href: `/insurance/${carrier.slug}/${service.slug}/`, current: true },
];

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs);

// Other services covered by this carrier
const otherServices = services.filter(s => 
  carrier.coveredServices?.includes(s.slug as any) && s.slug !== serviceSlug
);
const priorityCityLinks = cities
  .filter((city) => city.services.includes(service.slug as any))
  .sort((a, b) => a.tier - b.tier || a.name.localeCompare(b.name))
  .slice(0, 5)
  .map((city) => ({
    label: `${service.name} in ${city.name}`,
    href: `/service-area/${city.slug}/${service.slug}/`,
  }));

// FAQs specific to this carrier + service combination
const faqs: FAQType[] = [
  {
    question: `Does ${carrier.name} cover ${service.name.toLowerCase()}?`,
    answer: insuranceService?.coverageOverview || `Coverage depends on your policy, cause of loss, and ${carrier.name} review. Sudden and accidental losses may be eligible, and we document visible damage, moisture readings, photos, and scope notes for adjuster evaluation.`,
  },
  {
    question: `What's my out-of-pocket cost for ${service.name.toLowerCase()} with ${carrier.name}?`,
    answer: `Your out-of-pocket cost depends on your deductible, coverage, cause of loss, and ${carrier.name} review. We provide detailed documentation so your carrier can evaluate covered restoration work clearly.`,
  },
  {
    question: `How quickly can you start ${service.name.toLowerCase()} with a ${carrier.name} claim?`,
    answer: `We can begin emergency ${service.name.toLowerCase()} within 60 minutes of your call. Emergency mitigation may be needed quickly to protect the property. We document the loss and help coordinate with your adjuster while coverage is reviewed.`,
  },
  {
    question: `What documentation does ${carrier.name} need for ${service.name.toLowerCase()}?`,
    answer: insuranceService?.documentationNeeded ? `${carrier.name} typically requires: ${insuranceService.documentationNeeded.join(', ')}. We prepare organized documentation for you and your adjuster.` : `We provide organized documentation including photos, moisture readings, damage assessments, and detailed reports for ${carrier.name} adjuster review.`,
  },
  {
    question: `Can billing be coordinated with ${carrier.name} for ${service.name.toLowerCase()}?`,
    answer: `Billing coordination depends on your policy, claim status, and carrier review. We help coordinate documentation, adjuster communication, and billing when applicable so the process is easier to manage.`,
  },
];

const serviceSchema = getServiceSchema(service, {
  pagePath: `/insurance/${carrier.slug}/${service.slug}/`,
  includeOfferCatalog: false,
});
const faqSchema = getFAQSchema(faqs);
const jsonLd = combineSchemas(breadcrumbSchema, serviceSchema, faqSchema);
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative bg-brand-black overflow-hidden min-h-[450px] lg:min-h-[500px] flex items-center">
    <div class="absolute inset-0">
      <img
        src={service.image || '/images/hero/truck-hero.webp'}
        alt={`${service.name} with ${carrier.name} insurance`}
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
        width="1500"
        height="1000"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-brand-black/85 via-brand-black/60 to-brand-black/40"></div>
    </div>
    
    <div class="container relative py-16 lg:py-20">
      <Breadcrumbs items={breadcrumbs} variant="dark" class="mb-6" showSchema={false} />
      
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/40 text-brand-orange px-4 py-2 rounded-full text-sm font-medium mb-6">
            <Icon name="shield" size="sm" />
            {carrier.name} Claim Support
          </div>
          
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white mb-6 leading-[1.1] tracking-tight">
            {service.name} with{' '}
            <span class="text-brand-orange">{carrier.name}</span>
          </h1>
          
          <p class="text-brand-cream-300 text-lg lg:text-xl mb-8 max-w-xl leading-relaxed">
            Need {service.name.toLowerCase()} and have {carrier.name}? We provide emergency restoration, document the loss, and help coordinate adjuster communication and billing when applicable.
          </p>
          
          <div class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm mb-8">
            <div class="flex items-center gap-2 text-brand-cream-300">
              <Icon name="clock" size="sm" class="text-brand-orange" />
              <span>60-Minute Response</span>
            </div>
            <div class="flex items-center gap-2 text-brand-cream-300">
              <Icon name="file-text" size="sm" class="text-brand-orange" />
              <span>{carrier.name} Billing Coordination</span>
            </div>
            <div class="flex items-center gap-2 text-brand-cream-300">
              <Icon name="award" size="sm" class="text-brand-orange" />
              <span>IICRC Certified</span>
            </div>
          </div>
          
          <div class="hidden lg:flex items-center gap-6">
            <PhoneCTA
              phone={business.phone}
              phoneFormatted={business.phoneFormatted}
              ctaLocation="insurance_service_hero"
              class="group flex items-center gap-3 text-white hover:text-brand-orange transition-colors"
            >
              <span class="flex items-center justify-center w-12 h-12 rounded-full bg-brand-orange group-hover:bg-brand-orange-600 transition-colors">
                <Icon name="phone" size="md" class="text-white" />
              </span>
              <span>
                <span class="block text-sm text-brand-cream-400">Call 24/7</span>
                <span class="block font-bold text-xl tracking-tight">{business.phoneFormatted}</span>
              </span>
            </PhoneCTA>
          </div>
        </div>
        
        <div class="hidden lg:block lg:col-span-5">
          <LeadForm 
            variant="card"
            title={`${carrier.name} ${service.name}`}
            subtitle="We help document your insurance claim"
            source={`insurance-${carrierSlug}-${serviceSlug}`}
          />
        </div>
      </div>
    </div>
  </section>
  
  <TrustBar variant="light" />
  
  <!-- Coverage Overview -->
  <section class="section bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-black mb-6 text-center">
          {service.name} Coverage with {carrier.name}
        </h2>
        
        <div class="prose prose-lg mx-auto mb-12">
          <p class="text-lg text-brand-gray leading-relaxed">
            {insuranceService?.coverageOverview || `When you need ${service.name.toLowerCase()} and have ${carrier.name} insurance, you want a restoration company that knows how to work with your carrier. Tamarack Restoration has extensive experience with ${carrier.name} claims throughout North San Diego County.`}
          </p>
          <p class="text-lg text-brand-gray leading-relaxed">
            We help with the process from initial documentation through adjuster communication. Our team prepares photos, moisture readings, scope notes, and professional assessments for {carrier.name} review.
          </p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Process Steps (from service content) -->
  {svcContent?.processSteps && (
    <section class="section bg-brand-cream-200">
      <div class="container">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-black mb-4">
            Our {service.name} Process
          </h2>
          <p class="text-lg text-brand-gray">
            Professional restoration coordinated with your {carrier.name} claim.
          </p>
        </div>
        
        <div class="max-w-4xl mx-auto">
          <div class="space-y-6">
            {svcContent.processSteps.slice(0, 5).map((step, index) => (
              <div class="flex gap-6 items-start bg-white rounded-xl p-6 shadow-soft">
                <div class="flex-shrink-0 w-12 h-12 rounded-full bg-brand-orange text-white flex items-center justify-center font-heading font-bold text-xl">
                  {index + 1}
                </div>
                <div>
                  <h3 class="font-heading font-bold text-brand-black text-xl mb-2">
                    {step.title}
                  </h3>
                  <p class="text-brand-gray">
                    {step.description}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}
  
  <!-- Documentation & Tips -->
  {insuranceService && (
    <section class="section bg-white">
      <div class="container">
        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          {/* Documentation Needed */}
          {insuranceService.documentationNeeded && (
            <div class="bg-brand-cream-200 rounded-2xl p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-12 h-12 rounded-xl bg-brand-orange-100 flex items-center justify-center">
                  <Icon name="file-text" size="lg" class="text-brand-orange" />
                </div>
                <h3 class="font-heading font-bold text-brand-black text-xl">
                  Documentation We Provide
                </h3>
              </div>
              <p class="text-brand-gray mb-4 text-sm">
                We prepare everything {carrier.name} needs:
              </p>
              <ul class="space-y-3">
                {insuranceService.documentationNeeded.map((doc) => (
                  <li class="flex items-start gap-2">
                    <Icon name="check" size="sm" class="text-brand-orange mt-1 flex-shrink-0" />
                    <span class="text-brand-gray text-sm">{doc}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          
          {/* Claim Tips */}
          {insuranceService.serviceTips && (
            <div class="bg-brand-cream-200 rounded-2xl p-8">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-12 h-12 rounded-xl bg-brand-orange-100 flex items-center justify-center">
                  <Icon name="lightbulb" size="lg" class="text-brand-orange" />
                </div>
                <h3 class="font-heading font-bold text-brand-black text-xl">
                  Tips for Your Claim
                </h3>
              </div>
              <ul class="space-y-3">
                {insuranceService.serviceTips.map((tip) => (
                  <li class="flex items-start gap-2">
                    <Icon name="arrow-right" size="sm" class="text-brand-orange mt-1 flex-shrink-0" />
                    <span class="text-brand-gray text-sm">{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </section>
  )}
  
  <!-- What's Included -->
  <section class="section bg-brand-cream-200">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-black mb-4">
          What's Included in Your {carrier.name} Claim
        </h2>
        <p class="text-lg text-brand-gray">
          Full-service {service.name.toLowerCase()} with documentation and insurance coordination when applicable.
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {service.features?.map((feature) => (
          <div class="bg-white rounded-xl p-6 shadow-soft">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-brand-orange-100 flex items-center justify-center">
                <Icon name="check-circle" size="sm" class="text-brand-orange" />
              </div>
              <span class="font-heading font-semibold text-brand-black">{feature}</span>
            </div>
          </div>
        ))}
        <div class="bg-white rounded-xl p-6 shadow-soft">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-orange-100 flex items-center justify-center">
              <Icon name="check-circle" size="sm" class="text-brand-orange" />
            </div>
            <span class="font-heading font-semibold text-brand-black">Billing coordination when applicable</span>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-soft">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-orange-100 flex items-center justify-center">
              <Icon name="check-circle" size="sm" class="text-brand-orange" />
            </div>
            <span class="font-heading font-semibold text-brand-black">Adjuster coordination</span>
          </div>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-soft">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-brand-orange-100 flex items-center justify-center">
              <Icon name="check-circle" size="sm" class="text-brand-orange" />
            </div>
            <span class="font-heading font-semibold text-brand-black">Complete documentation</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  

  <!-- Related Core Service and Local Resources -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="rounded-2xl bg-brand-cream-200 p-8">
          <h2 class="mb-4 font-heading text-2xl font-bold text-brand-black">
            Core {service.name} Service Details
          </h2>
          <p class="mb-6 text-brand-gray">
            The insurance page explains documentation and claim coordination. The core service page explains the mitigation process, equipment, safety steps, and restoration scope in more detail.
          </p>
          <a href={`/services/${service.slug}/`} class="inline-flex items-center gap-2 font-semibold text-brand-orange hover:text-brand-orange-600">
            View {service.name} service details
            <Icon name="arrow-right" size="sm" />
          </a>
        </div>

        <div class="rounded-2xl bg-brand-cream-200 p-8">
          <h2 class="mb-4 font-heading text-2xl font-bold text-brand-black">
            Local {service.name} Resources
          </h2>
          <p class="mb-6 text-brand-gray">
            Browse city-specific restoration pages for response expectations, local property concerns, and service-area details.
          </p>
          <div class="grid gap-3 sm:grid-cols-2">
            {priorityCityLinks.map((link) => (
              <a href={link.href} class="group rounded-lg bg-white p-4 text-sm font-semibold text-brand-black transition-colors hover:bg-brand-orange hover:text-white">
                {link.label}
                <Icon name="arrow-right" size="sm" class="ml-1 inline text-brand-orange group-hover:text-white" />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Services -->
  {otherServices.length > 0 && (
    <section class="section bg-white">
      <div class="container">
        <div class="text-center max-w-3xl mx-auto mb-10">
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-brand-black mb-4">
            Other {carrier.name} Claim Support Services
          </h2>
          <p class="text-lg text-brand-gray">
            We also help document these restoration services for {carrier.name} review when applicable.
          </p>
        </div>
        
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
          {otherServices.map((otherService) => (
            <a 
              href={`/insurance/${carrier.slug}/${otherService.slug}/`}
              class="group flex items-center gap-3 p-4 bg-brand-cream-200 rounded-lg hover:bg-brand-orange hover:text-white transition-colors"
            >
              <Icon name={otherService.icon} size="md" class="text-brand-orange group-hover:text-white flex-shrink-0" />
              <span class="font-heading font-semibold text-brand-black group-hover:text-white">
                {otherService.name}
              </span>
              <Icon name="arrow-right" size="sm" class="ml-auto text-brand-gray group-hover:text-white" />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  
  <Testimonials limit={3} class="bg-brand-cream-200" />
  
  <!-- FAQ — FAQPage schema already injected in <head> via jsonLd; suppress inline re-injection -->
  <FAQ
    title={`${carrier.name} ${service.name} FAQs`}
    subtitle="Common questions about insurance coverage"
    faqs={faqs}
    showViewAll={false}
    showSchema={false}
    class="bg-white"
  />
  
  <!-- Mobile Form -->
  <section class="section lg:hidden bg-brand-cream-200">
    <div class="container">
      <LeadForm 
        variant="card"
        title={`${carrier.name} ${service.name}`}
        subtitle="We help document your insurance claim"
        source={`insurance-${carrierSlug}-${serviceSlug}-mobile`}
      />
    </div>
  </section>
</BaseLayout>
