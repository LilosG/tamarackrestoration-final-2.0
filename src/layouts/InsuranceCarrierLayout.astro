---
/**
 * Insurance Carrier Layout
 * ========================
 * Template for /insurance/[carrier]/ pages
 * Enhanced with rich content from insuranceCarrierContent
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import PhoneCTA from '@/components/PhoneCTA.astro';
import TrustBar from '@/components/sections/TrustBar.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import FAQ from '@/components/sections/FAQ.astro';
import LeadForm from '@/components/forms/LeadForm.astro';
import { insuranceCarriers, services, business } from '@/data/site';
import { insuranceCarrierContent } from '@/data/content';
import {
  getCanonicalUrl,
  getBreadcrumbSchema,
  getServiceSchema,
  getFAQSchema,
  combineSchemas,
} from '@/utils/seo';
import type { FAQ as FAQType } from '@/types';

interface Props {
  carrierSlug: string;
}

const { carrierSlug } = Astro.props;

const carrier = insuranceCarriers.find((c) => c.slug === carrierSlug)!;
const content = insuranceCarrierContent[carrierSlug] || null;
const coveredServices = services.filter((s) => carrier.coveredServices?.includes(s.slug as any));

// SEO
const title = `${carrier.name} Insurance Claims | Tamarack Restoration`;
const description = `We work directly with ${carrier.name} for water damage, fire, mold, and flood restoration claims in North San Diego County. Direct billing, thorough documentation. Call ${business.phoneFormatted}.`;
const canonical = getCanonicalUrl(`/insurance/${carrier.slug}/`);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Insurance', href: '/insurance/' },
  { label: carrier.name, href: `/insurance/${carrier.slug}/`, current: true },
];

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs);

// Service schemas — one per covered service on this carrier page
const serviceSchemas = coveredServices.map((svc) =>
  getServiceSchema(svc, { pagePath: `/services/${svc.slug}/`, includeOfferCatalog: false })
);

// Use content data for claim steps or fallback
const claimSteps = content?.claimSteps || [
  { title: 'Document Damage', description: 'Take photos and videos of all damage.' },
  { title: 'File Your Claim', description: `Contact ${carrier.name} to open your claim.` },
  { title: 'Call Tamarack', description: 'We begin emergency service immediately.' },
  { title: 'Adjuster Coordination', description: 'We work directly with your adjuster.' },
  { title: 'Restoration Complete', description: 'We restore and bill your insurance directly.' },
];

// Insurance-specific FAQs
const faqs: FAQType[] = [
  {
    question: `Does ${carrier.name} cover water damage restoration?`,
    answer: `Yes, ${carrier.name} typically covers sudden and accidental water damage like burst pipes and appliance failures. We work directly with ${carrier.name} adjusters to document damage and maximize your claim.`,
  },
  {
    question: `How do I file a ${carrier.name} claim for property damage?`,
    answer: `First, document all damage with photos. Then contact ${carrier.name} to open a claim. Call us at ${business.phoneFormatted} for emergency service—we begin work immediately and coordinate with your adjuster.`,
  },
  {
    question: `Will I have to pay out of pocket with ${carrier.name}?`,
    answer: `You'll typically be responsible for your deductible. We work with ${carrier.name} to ensure all covered damage is documented so you receive the full benefits of your policy.`,
  },
  {
    question: `How long does the ${carrier.name} claims process take?`,
    answer: `Claim timelines vary, but we work to expedite the process. We provide detailed documentation, meet with adjusters on-site, and communicate directly with ${carrier.name} to keep your claim moving.`,
  },
  {
    question: `Does ${carrier.name} cover mold removal?`,
    answer: `${carrier.name} typically covers mold remediation when it results from a covered water damage event and is addressed promptly. We document the connection between water damage and mold to support your claim.`,
  },
];

const faqSchema = getFAQSchema(faqs);
const jsonLd = combineSchemas(breadcrumbSchema, faqSchema, ...serviceSchemas);

// Precompute service area cross-links for insurance pages
const serviceAreaCities = [
  { city: 'Carlsbad', slug: 'carlsbad' },
  { city: 'Oceanside', slug: 'oceanside' },
  { city: 'Vista', slug: 'vista' },
  { city: 'San Marcos', slug: 'san-marcos' },
  { city: 'Encinitas', slug: 'encinitas' },
  { city: 'Solana Beach', slug: 'solana-beach' },
];
const serviceAreaLinks: { label: string; href: string }[] = [];
for (const svc of coveredServices.slice(0, 2)) {
  for (const cityItem of serviceAreaCities) {
    serviceAreaLinks.push({
      label: `${svc.name} — ${cityItem.city}`,
      href: `/service-area/${cityItem.slug}/${svc.slug}/`,
    });
  }
}
---

<BaseLayout title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <!-- Hero -->
  <section
    class="relative flex min-h-[450px] items-center overflow-hidden bg-brand-black lg:min-h-[500px]"
  >
    <div
      class="absolute inset-0 bg-gradient-to-r from-brand-black/85 via-brand-black/60 to-brand-black/40"
    >
    </div>

    <div class="container relative py-16 lg:py-20">
      <Breadcrumbs items={breadcrumbs} variant="dark" class="mb-6" showSchema={false} />

      <div class="grid items-center gap-8 lg:grid-cols-12 lg:gap-12">
        <div class="lg:col-span-7">
          <!-- Carrier Logo -->
          <div class="mb-6">
            <img
              src={carrier.logo}
              alt={`${carrier.name} Insurance Logo`}
              class="h-12 w-auto object-contain"
              loading="eager"
              width={carrier.logoWidth}
              height={carrier.logoHeight}
            />
          </div>

          <div
            class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-orange/40 bg-brand-orange/20 px-4 py-2 text-sm font-medium text-brand-orange"
          >
            <Icon name="shield" size="sm" />
            Insurance Partner
          </div>

          <h1
            class="mb-6 font-heading text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl"
          >
            We Work With{' '}
            <span class="text-brand-orange">{carrier.name}</span>
          </h1>

          <p class="mb-8 max-w-xl text-lg leading-relaxed text-brand-cream-300 lg:text-xl">
            {carrier.description} We handle the paperwork so you can focus on your family.
          </p>

          <div class="mb-8 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm">
            <div class="flex items-center gap-2 text-brand-cream-300">
              <Icon name="check-circle" size="sm" class="text-brand-orange" />
              <span>Direct {carrier.name} Billing</span>
            </div>
            <div class="flex items-center gap-2 text-brand-cream-300">
              <Icon name="file-text" size="sm" class="text-brand-orange" />
              <span>Full Documentation</span>
            </div>
            <div class="flex items-center gap-2 text-brand-cream-300">
              <Icon name="clock" size="sm" class="text-brand-orange" />
              <span>60-Minute Response</span>
            </div>
          </div>

          <div class="hidden items-center gap-6 lg:flex">
            <PhoneCTA
              phone={business.phone}
              phoneFormatted={business.phoneFormatted}
              ctaLocation="insurance_carrier_hero"
              class="group flex items-center gap-3 text-white transition-colors hover:text-brand-orange"
            >
              <span
                class="flex h-12 w-12 items-center justify-center rounded-full bg-brand-orange transition-colors group-hover:bg-brand-orange-600"
              >
                <Icon name="phone" size="md" class="text-white" />
              </span>
              <span>
                <span class="block text-sm text-brand-cream-400">Call 24/7</span>
                <span class="block text-xl font-bold tracking-tight">{business.phoneFormatted}</span
                >
              </span>
            </PhoneCTA>
          </div>
        </div>

        <div class="hidden lg:col-span-5 lg:block">
          <LeadForm
            variant="card"
            title={`${carrier.name} Claim Help`}
            subtitle="We handle the insurance process"
            source={`insurance-${carrierSlug}`}
          />
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <!-- How We Help Section -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid items-start gap-12 lg:grid-cols-2">
        <div>
          <div
            class="mb-4 inline-flex items-center gap-2 rounded-full bg-brand-orange-100 px-4 py-2 text-body-sm font-semibold text-brand-orange"
          >
            <Icon name="users" size="sm" />
            Your Claims Partner
          </div>

          <h2 class="mb-6 font-heading text-3xl font-bold text-brand-black md:text-4xl">
            How We Help {carrier.name} Policyholders
          </h2>

          <div class="space-y-4 text-brand-gray">
            <p class="text-lg leading-relaxed">
              {
                content?.howWeHelp ||
                  `Filing a ${carrier.name} claim after property damage is stressful. We make it easier by working directly with ${carrier.name} on your behalf.`
              }
            </p>
            <p class="leading-relaxed">
              Our team understands what {carrier.name} adjusters need to approve claims quickly. We provide
              detailed documentation, professional assessments, and clear communication throughout the
              restoration process.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            <Button
              href={`tel:${business.phone}`}
              variant="primary"
              onclick={`if(window.gtag){window.gtag('event','click_to_call',{phone_number:'${business.phone}',cta_location:'insurance_carrier_cta',page_path:window.location.pathname});}`}
            >
              <Icon name="phone" size="sm" />
              Call {business.phoneFormatted}
            </Button>
            <Button href="/contact/" variant="outline"> Request Free Estimate </Button>
          </div>
        </div>

        <div class="rounded-2xl bg-brand-cream-200 p-8">
          <h3 class="mb-6 font-heading text-xl font-bold text-brand-black">
            The {carrier.name} Claims Process
          </h3>
          <div class="space-y-4">
            {
              claimSteps.map((step, index) => (
                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-brand-orange font-bold text-white">
                    {index + 1}
                  </div>
                  <div>
                    <h4 class="font-heading font-semibold text-brand-black">{step.title}</h4>
                    <p class="text-sm text-brand-gray">{step.description}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Covered Section -->
  {
    content && (
      <section class="section bg-brand-cream-200">
        <div class="container">
          <div class="mx-auto mb-12 max-w-3xl text-center">
            <h2 class="mb-4 font-heading text-3xl font-bold text-brand-black md:text-4xl">
              {carrier.name} Coverage Guide
            </h2>
            <p class="text-lg text-brand-gray">
              Understanding what your {carrier.name} policy covers helps you know what to expect.
            </p>
          </div>

          <div class="mx-auto grid max-w-5xl gap-8 md:grid-cols-2">
            {content.typicallyCovered && (
              <div class="rounded-2xl bg-white p-8 shadow-soft">
                <div class="mb-6 flex items-center gap-3">
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-success-50">
                    <Icon name="check-circle" size="lg" class="text-success-500" />
                  </div>
                  <h3 class="font-heading text-xl font-bold text-brand-black">Typically Covered</h3>
                </div>
                <ul class="space-y-3">
                  {content.typicallyCovered.map((item) => (
                    <li class="flex items-start gap-2">
                      <Icon name="check" size="sm" class="mt-1 flex-shrink-0 text-success-500" />
                      <span class="text-brand-gray">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {content.mayNotBeCovered && (
              <div class="rounded-2xl bg-white p-8 shadow-soft">
                <div class="mb-6 flex items-center gap-3">
                  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-warning-50">
                    <Icon name="alert-triangle" size="lg" class="text-warning-500" />
                  </div>
                  <h3 class="font-heading text-xl font-bold text-brand-black">
                    May Require Additional Coverage
                  </h3>
                </div>
                <ul class="space-y-3">
                  {content.mayNotBeCovered.map((item) => (
                    <li class="flex items-start gap-2">
                      <Icon
                        name="alert-circle"
                        size="sm"
                        class="mt-1 flex-shrink-0 text-warning-500"
                      />
                      <span class="text-brand-gray">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        </div>
      </section>
    )
  }

  <!-- Services Covered -->
  <section class="section bg-white">
    <div class="container">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <h2 class="mb-4 font-heading text-3xl font-bold text-brand-black md:text-4xl">
          Restoration Services for {carrier.name} Claims
        </h2>
        <p class="text-lg text-brand-gray">
          We provide these services and coordinate directly with {carrier.name} for your claim.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {
          coveredServices.map((service) => (
            <a
              href={`/insurance/${carrier.slug}/${service.slug}/`}
              class="group rounded-xl border border-brand-cream-300 bg-white p-6 transition-all hover:border-brand-orange hover:shadow-card"
            >
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-orange-100 text-brand-orange transition-colors group-hover:bg-brand-orange group-hover:text-white">
                <Icon name={service.icon} size="lg" />
              </div>
              <h3 class="mb-2 font-heading text-lg font-bold text-brand-black transition-colors group-hover:text-brand-orange">
                {service.name}
              </h3>
              <p class="mb-3 text-sm text-brand-gray">{service.shortDescription}</p>
              <span class="inline-flex items-center gap-1 text-sm font-semibold text-brand-orange">
                {carrier.name} Claims
                <Icon name="arrow-right" size="sm" />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Service Area Cross-Links -->
  <section class="section bg-white">
    <div class="container">
      <div class="mx-auto mb-10 max-w-3xl text-center">
        <h2 class="mb-4 font-heading text-3xl font-bold text-brand-black">
          {carrier.name} Claims in Your Area
        </h2>
        <p class="text-lg text-brand-gray">
          We serve all of North San Diego County. Select your city for local response times and
          service details.
        </p>
      </div>
      <div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          serviceAreaLinks.map((link) => (
            <a
              href={link.href}
              class="group flex items-center gap-3 rounded-lg bg-brand-cream-200 p-4 transition-colors hover:bg-brand-orange-100"
            >
              <Icon name="map-pin" size="sm" class="flex-shrink-0 text-brand-orange" />
              <span class="text-sm font-medium text-brand-black transition-colors group-hover:text-brand-orange">
                {link.label}
              </span>
            </a>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a
          href="/service-area/"
          class="inline-flex items-center gap-2 font-semibold text-brand-orange hover:underline"
        >
          View all service areas
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section bg-brand-cream-200">
    <div class="container">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <h2 class="mb-4 font-heading text-3xl font-bold text-brand-black md:text-4xl">
          Why {carrier.name} Customers Choose Tamarack
        </h2>
      </div>

      <div class="mx-auto grid max-w-5xl gap-8 md:grid-cols-3">
        {
          (
            content?.whyChooseUs || [
              {
                title: 'Complete Documentation',
                description: `Detailed reports that ${carrier.name} adjusters need.`,
              },
              {
                title: 'Direct Communication',
                description: `We coordinate directly with your ${carrier.name} adjuster.`,
              },
              {
                title: 'Maximize Your Claim',
                description: 'Thorough assessments ensure all damage is documented.',
              },
            ]
          ).map((reason) => (
            <div class="rounded-2xl bg-white p-6 text-center shadow-soft">
              <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-brand-orange-100">
                <Icon name="check-circle" size="lg" class="text-brand-orange" />
              </div>
              <h3 class="mb-3 font-heading text-xl font-bold text-brand-black">{reason.title}</h3>
              <p class="text-brand-gray">{reason.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Claim Tips -->
  {
    content?.claimTips && (
      <section class="section bg-white">
        <div class="container">
          <div class="mx-auto max-w-4xl">
            <div class="rounded-2xl bg-brand-cream-200 p-8">
              <h3 class="mb-6 text-center font-heading text-xl font-bold text-brand-black">
                Tips for {carrier.name} Policyholders
              </h3>
              <div class="grid gap-4 sm:grid-cols-2">
                {content.claimTips.map((tip) => (
                  <div class="flex items-start gap-3 rounded-lg bg-white p-4">
                    <Icon
                      name="lightbulb"
                      size="sm"
                      class="mt-0.5 flex-shrink-0 text-brand-orange"
                    />
                    <span class="text-sm text-brand-gray">{tip}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <Testimonials limit={3} class="bg-brand-cream-200" />

  <!-- FAQ — FAQPage schema already injected in <head> via jsonLd; suppress inline re-injection -->
  <FAQ
    title={`${carrier.name} Insurance FAQs`}
    subtitle="Common questions about insurance claims"
    faqs={faqs}
    showViewAll={false}
    showSchema={false}
    class="bg-white"
  />

  <!-- Mobile Form -->
  <section class="section bg-brand-cream-200 lg:hidden">
    <div class="container">
      <LeadForm
        variant="card"
        title={`${carrier.name} Claim Help`}
        subtitle="We handle the insurance process"
        source={`insurance-${carrierSlug}-mobile`}
      />
    </div>
  </section>
</BaseLayout>
