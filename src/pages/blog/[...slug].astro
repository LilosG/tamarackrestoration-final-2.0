---
/**
 * Dynamic Blog Post Route
 * =======================
 * Renders individual blog posts from content collection
 */

import { getCollection } from 'astro:content';
import BlogPostLayout from '@/layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  const postsByDate = [...posts].sort(
    (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime(),
  );

  return postsByDate.map((post) => {
    const moreArticles = postsByDate
      .filter((candidate) => candidate.slug !== post.slug)
      .slice(0, 3);

    return {
      params: { slug: post.slug },
      props: { post, moreArticles },
    };
  });
}

const { post, moreArticles } = Astro.props;
const { Content } = await post.render();
---

<BlogPostLayout post={post} moreArticles={moreArticles}>
  <Content />
</BlogPostLayout>
