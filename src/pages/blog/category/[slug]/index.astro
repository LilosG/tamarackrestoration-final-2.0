---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import TrustBar from '@/components/sections/TrustBar.astro';
import PriorityInternalLinks from '@/components/sections/PriorityInternalLinks.astro';
import { allServices } from '@/data/site';
import {
  getCategorySlugsFromPosts,
  getCategoryHub,
  getCategoryNameMap,
} from '@/lib/blogTaxonomy';
import { getCanonicalUrl, getBreadcrumbSchema, getWebPageSchema, combineSchemas } from '@/utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const slugs = getCategorySlugsFromPosts(posts);

  return slugs.map((slug) => ({
    params: { slug },
    props: { slug },
  }));
}

const { slug } = Astro.props as { slug: string };
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const category = getCategoryHub(slug);
const posts = allPosts
  .filter((post) => post.data.category === slug)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const categoryNames = getCategoryNameMap(allPosts);
const relatedServices = category.relatedServiceSlugs
  .map((serviceSlug) => allServices.find((service) => service.slug === serviceSlug))
  .filter(Boolean);
const supportLinkGroups = [];
if (relatedServices.length > 0) {
  supportLinkGroups.push({
    title: 'Core Services',
    description: 'Service pages with process details, equipment notes, and emergency response options.',
    links: relatedServices.map((service) => ({
      label: service!.name,
      href: `/services/${service!.slug}/`,
      description: service!.shortDescription,
    })),
  });
}
if (category.relatedCityServiceLinks.length > 0) {
  supportLinkGroups.push({
    title: 'Local Resources',
    description: 'Relevant city and service pages for readers who need local restoration help.',
    links: category.relatedCityServiceLinks.map((link) => ({
      label: link.label,
      href: link.href,
      description: link.context,
    })),
  });
}

const canonical = getCanonicalUrl(`/blog/category/${slug}/`);
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Categories', href: '/blog/category/' },
  { label: category.label, href: `/blog/category/${slug}/`, current: true },
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs);
const webPageSchema = getWebPageSchema({
  url: canonical,
  name: category.title,
  description: category.metaDescription,
  breadcrumb: breadcrumbSchema,
});
const jsonLd = combineSchemas(breadcrumbSchema, webPageSchema);
---

<BaseLayout title={category.title} description={category.metaDescription} canonical={canonical} jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-brand-black">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-black via-brand-black/95 to-brand-orange/20"></div>
    <div class="container relative py-16 lg:py-20">
      <Breadcrumbs items={breadcrumbs} variant="dark" class="mb-6" showSchema={false} />
      <div class="max-w-3xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-orange/40 bg-brand-orange/20 px-4 py-2 text-sm font-medium text-brand-orange">
          <Icon name={category.icon} size="sm" />
          {category.label} Hub
        </div>
        <h1 class="mb-6 font-heading text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
          {category.h1}
        </h1>
        <p class="text-lg leading-relaxed text-brand-cream-300 lg:text-xl">
          {category.intro}
        </p>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="border-b border-brand-cream-300 bg-white py-8">
    <div class="container">
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/blog/" class="rounded-full bg-brand-cream-200 px-4 py-2 text-sm font-medium text-brand-gray transition-colors hover:bg-brand-orange hover:text-white">
          All Posts
        </a>
        <a href="/blog/category/" class="rounded-full bg-brand-cream-200 px-4 py-2 text-sm font-medium text-brand-gray transition-colors hover:bg-brand-orange hover:text-white">
          All Categories
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-brand-orange">
            {posts.length} article{posts.length === 1 ? '' : 's'} in this hub
          </p>
          <h2 class="font-heading text-3xl font-bold text-brand-black">Latest {category.label} Guides</h2>
        </div>
        <Button href="/blog/" variant="outline">
          Back to Blog
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} categoryNames={categoryNames} />)}
      </div>
    </div>
  </section>

  <PriorityInternalLinks
    title={`Related ${category.label} Services`}
    subtitle="When an article points to a real restoration need, these central service and local pages provide a practical next step."
    groups={supportLinkGroups}
    class="bg-brand-cream-200"
  />
</BaseLayout>
