---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import Icon from '@/components/ui/Icon.astro';
import Button from '@/components/ui/Button.astro';
import TrustBar from '@/components/sections/TrustBar.astro';
import { allServices } from '@/data/site';
import {
  getCategorySlugsFromPosts,
  getCategoryHub,
  getCategoryNameMap,
} from '@/lib/blogTaxonomy';
import { getCanonicalUrl, getBreadcrumbSchema, getWebPageSchema, combineSchemas } from '@/utils/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const slugs = getCategorySlugsFromPosts(posts);

  return slugs.map((slug) => ({
    params: { slug },
    props: { slug },
  }));
}

const { slug } = Astro.props as { slug: string };
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const category = getCategoryHub(slug);
const posts = allPosts
  .filter((post) => post.data.category === slug)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
const categoryNames = getCategoryNameMap(allPosts);
const relatedServices = category.relatedServiceSlugs
  .map((serviceSlug) => allServices.find((service) => service.slug === serviceSlug))
  .filter(Boolean);

const canonical = getCanonicalUrl(`/blog/category/${slug}/`);
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Categories', href: '/blog/category/' },
  { label: category.label, href: `/blog/category/${slug}/`, current: true },
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs);
const webPageSchema = getWebPageSchema({
  url: canonical,
  name: category.title,
  description: category.metaDescription,
  breadcrumb: breadcrumbSchema,
});
const jsonLd = combineSchemas(breadcrumbSchema, webPageSchema);
---

<BaseLayout title={category.title} description={category.metaDescription} canonical={canonical} jsonLd={jsonLd}>
  <section class="relative overflow-hidden bg-brand-black">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-black via-brand-black/95 to-brand-orange/20"></div>
    <div class="container relative py-16 lg:py-20">
      <Breadcrumbs items={breadcrumbs} variant="dark" class="mb-6" showSchema={false} />
      <div class="max-w-3xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-brand-orange/40 bg-brand-orange/20 px-4 py-2 text-sm font-medium text-brand-orange">
          <Icon name={category.icon} size="sm" />
          {category.label} Hub
        </div>
        <h1 class="mb-6 font-heading text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
          {category.h1}
        </h1>
        <p class="text-lg leading-relaxed text-brand-cream-300 lg:text-xl">
          {category.intro}
        </p>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="border-b border-brand-cream-300 bg-white py-8">
    <div class="container">
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/blog/" class="rounded-full bg-brand-cream-200 px-4 py-2 text-sm font-medium text-brand-gray transition-colors hover:bg-brand-orange hover:text-white">
          All Posts
        </a>
        <a href="/blog/category/" class="rounded-full bg-brand-cream-200 px-4 py-2 text-sm font-medium text-brand-gray transition-colors hover:bg-brand-orange hover:text-white">
          All Categories
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-brand-orange">
            {posts.length} article{posts.length === 1 ? '' : 's'} in this hub
          </p>
          <h2 class="font-heading text-3xl font-bold text-brand-black">Latest {category.label} Guides</h2>
        </div>
        <Button href="/blog/" variant="outline">
          Back to Blog
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <BlogCard post={post} categoryNames={categoryNames} />)}
      </div>
    </div>
  </section>

  {(relatedServices.length > 0 || category.relatedCityServiceLinks.length > 0) && (
    <section class="section bg-brand-cream-200">
      <div class="container">
        <div class="mb-10 max-w-3xl">
          <h2 class="mb-4 font-heading text-3xl font-bold text-brand-black">
            Related {category.label} Services
          </h2>
          <p class="text-brand-gray">
            When an article points to a real restoration need, these central service and local pages provide the next step without relying on thin archive content.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-2">
          {relatedServices.length > 0 && (
            <div class="rounded-2xl bg-white p-8 shadow-soft">
              <h3 class="mb-5 font-heading text-xl font-bold text-brand-black">Core Services</h3>
              <div class="space-y-3">
                {relatedServices.map((service) => service && (
                  <a href={`/services/${service.slug}/`} class="group flex items-center gap-3 rounded-xl border border-brand-cream-300 p-4 transition-colors hover:border-brand-orange hover:bg-brand-orange-50">
                    <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-orange-100 text-brand-orange">
                      <Icon name={service.icon} size="md" />
                    </span>
                    <span>
                      <span class="block font-heading font-semibold text-brand-black group-hover:text-brand-orange">{service.name}</span>
                      <span class="block text-sm text-brand-gray">{service.shortDescription}</span>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {category.relatedCityServiceLinks.length > 0 && (
            <div class="rounded-2xl bg-white p-8 shadow-soft">
              <h3 class="mb-5 font-heading text-xl font-bold text-brand-black">Local Resources</h3>
              <div class="space-y-3">
                {category.relatedCityServiceLinks.map((link) => (
                  <a href={link.href} class="group block rounded-xl border border-brand-cream-300 p-4 transition-colors hover:border-brand-orange hover:bg-brand-orange-50">
                    <span class="mb-1 flex items-center gap-2 font-heading font-semibold text-brand-black group-hover:text-brand-orange">
                      {link.label}
                      <Icon name="arrow-right" size="sm" />
                    </span>
                    <span class="text-sm text-brand-gray">{link.context}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
