---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Wheyland Electric | Carlsbad Electrician">
  <div class="bg-brand-indigo text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">An Innovative Electrician You Can Trust</h1>
      <p class="text-xl text-brand-columbia mb-8">Bright Ideas For Your Electrical Needs</p>
      <div class="flex gap-4 justify-center">
        <a href="/free-estimates/" class="bg-brand-cta hover:bg-brand-cta-hover text-white font-semibold px-6 py-3 rounded-lg transition-colors">Free Estimate</a>
        <a href="tel:8586635564" class="border-2 border-white text-white hover:bg-white hover:text-brand-indigo px-6 py-3 rounded-lg transition-colors font-semibold">Call (858) 663-5564</a>
      </div>
    </div>
  </div>
  <div class="bg-surface-subtle py-4">
    <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-6 text-sm text-text-muted font-medium">
      <span>Established 2008</span>
      <span class="hidden sm:inline text-brand-mint">|</span>
      <span>CA License #940291</span>
      <span class="hidden sm:inline text-brand-mint">|</span>
      <span>Licensed, Bonded &amp; Insured</span>
      <span class="hidden sm:inline text-brand-mint">|</span>
      <span>1-Year Labor Warranty</span>
    </div>
  </div>
</BaseLayout>
