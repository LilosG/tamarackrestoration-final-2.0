---
import { getCollection } from "astro:content";
import { slugify } from "../../../../lib/slug";

const SITE = new URL(import.meta.env.SITE ?? "https://www.tamarackrestoration.com");

type CategoryInfo = { name: string; slug: string };

function getAllCategories(posts: any[]): CategoryInfo[] {
  const map = new Map<string, string>(); // slug -> display name
  for (const p of posts) {
    const cats: string[] = p.data.categories ?? [];
    for (const name of cats) {
      const s = slugify(name);
      if (!s) continue;
      if (!map.has(s)) map.set(s, name);
    }
  }
  return [...map.entries()]
    .map(([slug, name]) => ({ slug, name }))
    .sort((a, b) => a.name.localeCompare(b.name));
}

const allPosts = await getCollection("blog", ({ data }) => !data.draft);

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const cats = getAllCategories(allPosts);
  return cats.map((c) => ({ params: { slug: c.slug }, props: { category: c } }));
}

const { slug } = Astro.params;
const { category } = Astro.props as { category: CategoryInfo };

const posts = allPosts
  .filter((p) => (p.data.categories ?? []).some((n: string) => slugify(n) === slug))
  .sort((a, b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate));

const title = `${category.name} | Tamarack Restoration Blog`;
const canonical = new URL(`/blog/category/${slug}/`, SITE).toString();

/**
 * Best-practice quality policy:
 * - Index taxonomy pages only when they are non-thin.
 * - Still allow crawlers to follow links.
 */
const robots = posts.length >= 2 ? "index,follow" : "noindex,follow";
---
<html lang="en">
  <head>
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robots} />
    <meta name="description" content={`Articles and guides related to ${category.name}.`} />
  </head>
  <body>
    <main class="mx-auto max-w-5xl px-4 py-10">
      <nav class="text-sm mb-6">
        <a class="underline" href="/blog/">Blog</a>
        <span class="mx-2">/</span>
        <a class="underline" href="/blog/category/">Categories</a>
        <span class="mx-2">/</span>
        <span>{category.name}</span>
      </nav>

      <h1 class="text-3xl font-semibold">{category.name}</h1>
      <p class="mt-2 text-base opacity-80">
        {posts.length} article{posts.length === 1 ? "" : "s"}
      </p>

      <ul class="mt-8 space-y-6">
        {posts.map((post) => (
          <li class="rounded-xl border p-5">
            <a class="text-xl font-medium underline" href={`/blog/${post.slug}/`}>
              {post.data.title}
            </a>
            <div class="mt-2 text-sm opacity-70">
              {new Date(post.data.pubDate).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </div>
            {post.data.description && <p class="mt-3">{post.data.description}</p>}
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
